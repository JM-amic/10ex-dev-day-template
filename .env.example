# Supabase (local dev, run by `supabase start`)
#
# Auth keys are NOT committed here: newer Supabase CLIs generate per-instance
# signing keys, so the anon/service_role values differ on every machine.
# `make up` reads the live keys from `supabase start` and injects them
# automatically (see scripts/supabase-env.sh) -- you do NOT need to fill these in.
# They only matter if you bypass make and run `docker compose up` directly, in
# which case run `make supabase-status` and paste the real values here.
#
# Two URLs intentionally differ by run context:
#   SUPABASE_URL       -> used by the Temporal worker, which runs INSIDE Docker and
#                         reaches the host-bound Supabase via host.docker.internal.
#   VITE_SUPABASE_URL  -> used by the frontend, which runs in the browser on the HOST.
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=injected-by-make-up
SUPABASE_SERVICE_ROLE_KEY=injected-by-make-up

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=main

# Frontend (browser on the host -> localhost)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=injected-by-make-up
VITE_API_URL=http://localhost:54321/functions/v1
