{
  "id": "debate-arena",
  "title": "Multi-Agent Debate Arena",
  "state": {
    "topic": "",
    "topicIsBlank": true,
    "roundCount": "3",
    "selectedPersonaKeys": [],
    "selectedPersonaCountValid": false,
    "submittedDebateId": null,
    "submitError": null,
    "isSubmitting": false
  },
  "dataSources": {
    "personas": {
      "type": "supabase",
      "table": "entities",
      "select": "*, entity_versions(*)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "debate_persona" },
        { "field": "source_record_id", "op": "neq", "value": "judge" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ]
    },
    "judgePersona": {
      "type": "supabase",
      "table": "entities",
      "select": "*, entity_versions(*)",
      "filters": [
        { "field": "entity_type", "op": "eq", "value": "debate_persona" },
        { "field": "source_record_id", "op": "eq", "value": "judge" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "single": true
    },
    "debate": {
      "type": "supabase",
      "table": "entities",
      "select": "*, entity_versions(*)",
      "filters": [
        { "field": "id", "op": "eq", "value": "{{state.submittedDebateId}}" },
        { "field": "entity_versions.is_current", "op": "eq", "value": true }
      ],
      "single": true,
      "enabled": "{{state.submittedDebateId}}",
      "refetchInterval": 2000,
      "pollUntilPath": "entity_versions[0].data.processing_status",
      "pollUntilValues": ["done", "error"]
    },
    "turns": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "child_id, created_at, entities!relationships_v2_child_id_fkey(*, entity_versions(*))",
      "filters": [
        { "field": "parent_id", "op": "eq", "value": "{{state.submittedDebateId}}" },
        { "field": "relationship_type", "op": "eq", "value": "debate_has_turn" }
      ],
      "order": [{ "column": "created_at", "ascending": true }],
      "enabled": "{{state.submittedDebateId}}",
      "refetchInterval": 2000
    },
    "verdict": {
      "type": "supabase",
      "table": "relationships_v2",
      "select": "child_id, entities!relationships_v2_child_id_fkey(*, entity_versions(*))",
      "filters": [
        { "field": "parent_id", "op": "eq", "value": "{{state.submittedDebateId}}" },
        { "field": "relationship_type", "op": "eq", "value": "debate_has_verdict" }
      ],
      "enabled": "{{state.submittedDebateId}}",
      "refetchInterval": 2000
    }
  },
  "layout": {
    "type": "Stack",
    "props": { "spacing": 6 },
    "children": [
      {
        "type": "Stack",
        "props": { "spacing": 1 },
        "children": [
          {
            "type": "Heading",
            "props": { "level": 1, "children": "Multi-Agent Debate Arena" }
          },
          {
            "type": "Text",
            "props": {
              "variant": "muted",
              "children": "Pick a topic and a few debaters with genuinely different lenses, then watch them argue it out."
            }
          }
        ]
      },
      {
        "type": "Card",
        "props": { "title": "Start a debate" },
        "children": [
          {
            "type": "Stack",
            "props": { "spacing": 4 },
            "children": [
              {
                "type": "Textarea",
                "props": {
                  "label": "Topic or decision",
                  "placeholder": "What are you trying to decide?",
                  "rows": 3,
                  "value": "{{state.topic}}",
                  "disabled": "{{state.isSubmitting}}",
                  "onChange": {
                    "action": "custom",
                    "handler": "updateTopic",
                    "payload": "{{event.target.value}}"
                  }
                }
              },
              {
                "type": "Stack",
                "props": { "spacing": 2 },
                "children": [
                  {
                    "type": "Text",
                    "props": { "weight": "medium", "size": "sm", "children": "Rounds" }
                  },
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "spacing": 2 },
                    "children": [
                      {
                        "type": "Button",
                        "props": {
                          "variant": "{{state.roundCount === '2' ? 'default' : 'outline'}}",
                          "disabled": "{{state.isSubmitting}}",
                          "children": "2 rounds",
                          "onClick": { "action": "setState", "key": "roundCount", "value": "2" }
                        }
                      },
                      {
                        "type": "Button",
                        "props": {
                          "variant": "{{state.roundCount === '3' ? 'default' : 'outline'}}",
                          "disabled": "{{state.isSubmitting}}",
                          "children": "3 rounds",
                          "onClick": { "action": "setState", "key": "roundCount", "value": "3" }
                        }
                      },
                      {
                        "type": "Button",
                        "props": {
                          "variant": "{{state.roundCount === '4' ? 'default' : 'outline'}}",
                          "disabled": "{{state.isSubmitting}}",
                          "children": "4 rounds",
                          "onClick": { "action": "setState", "key": "roundCount", "value": "4" }
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "PersonaPicker",
                "props": {
                  "label": "Debaters",
                  "personas": "{{data.personas}}",
                  "selectedKeys": "{{state.selectedPersonaKeys}}",
                  "min": 3,
                  "max": 5,
                  "onChange": {
                    "action": "sequence",
                    "actions": [
                      { "action": "setState", "key": "selectedPersonaKeys", "value": "{{event.selectedKeys}}" },
                      { "action": "setState", "key": "selectedPersonaCountValid", "value": "{{event.isValidCount}}" }
                    ]
                  }
                }
              },
              {
                "type": "Button",
                "props": {
                  "children": "Start Debate",
                  "loading": "{{state.isSubmitting}}",
                  "disabled": "{{state.isSubmitting || state.topicIsBlank || !state.selectedPersonaCountValid}}",
                  "onClick": {
                    "action": "custom",
                    "handler": "submitDebate",
                    "payload": { "round_count": "{{state.roundCount}}" }
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "type": "Alert",
        "if": "{{state.submitError}}",
        "props": {
          "variant": "destructive",
          "title": "Submission failed",
          "description": "{{state.submitError}}"
        }
      },
      {
        "type": "Stack",
        "if": "{{state.submittedDebateId}}",
        "props": { "spacing": 4 },
        "children": [
          {
            "type": "Skeleton",
            "if": "{{!data.debate}}",
            "props": { "height": 96 }
          },
          {
            "type": "Stack",
            "if": "{{data.debate}}",
            "props": { "direction": "horizontal", "spacing": 2, "align": "center" },
            "children": [
              {
                "type": "Badge",
                "if": "{{data.debate.entity_versions[0].data.processing_status === 'pending'}}",
                "props": { "variant": "secondary", "children": "Pending" }
              },
              {
                "type": "Badge",
                "if": "{{data.debate.entity_versions[0].data.processing_status === 'processing'}}",
                "props": { "variant": "secondary", "className": "animate-pulse", "children": "Processing" }
              },
              {
                "type": "Badge",
                "if": "{{data.debate.entity_versions[0].data.processing_status === 'done'}}",
                "props": { "className": "bg-emerald-600 hover:bg-emerald-600", "children": "Done" }
              },
              {
                "type": "Badge",
                "if": "{{data.debate.entity_versions[0].data.processing_status === 'error'}}",
                "props": { "variant": "destructive", "children": "Error" }
              },
              {
                "type": "Text",
                "props": {
                  "variant": "muted",
                  "size": "sm",
                  "children": "Round {{data.debate.entity_versions[0].data.current_round}} of {{data.debate.entity_versions[0].data.round_count}}"
                }
              }
            ]
          },
          {
            "type": "Alert",
            "if": "{{data.debate.entity_versions[0].data.processing_status === 'error'}}",
            "props": {
              "variant": "destructive",
              "title": "Debate failed",
              "description": "{{data.debate.entity_versions[0].data.error_message || 'The workflow reported an error.'}}"
            }
          },
          {
            "type": "Button",
            "if": "{{data.debate.entity_versions[0].data.processing_status === 'error'}}",
            "props": {
              "variant": "outline",
              "children": "Try again",
              "loading": "{{state.isSubmitting}}",
              "disabled": "{{state.isSubmitting}}",
              "onClick": {
                "action": "custom",
                "handler": "retryDebate"
              }
            }
          },
          {
            "type": "Card",
            "props": { "title": "Transcript" },
            "children": [
              {
                "type": "DebateTranscript",
                "props": {
                  "turns": "{{data.turns}}",
                  "personas": "{{data.debate.entity_versions[0].data.selected_personas}}"
                }
              }
            ]
          },
          {
            "type": "Card",
            "if": "{{data.debate.entity_versions[0].data.processing_status === 'done'}}",
            "props": { "title": "Verdict", "className": "border-amber-300 bg-amber-50/40" },
            "children": [
              {
                "type": "Stack",
                "props": { "spacing": 3 },
                "children": [
                  {
                    "type": "Stack",
                    "props": { "direction": "horizontal", "spacing": 3, "align": "center" },
                    "children": [
                      {
                        "type": "Text",
                        "props": {
                          "as": "div",
                          "className": "flex items-center justify-center h-10 w-10 rounded-full bg-amber-100 text-xl",
                          "children": "{{data.verdict[0].entities.entity_versions[0].data.persona_emoji}}"
                        }
                      },
                      {
                        "type": "Text",
                        "props": {
                          "weight": "semibold",
                          "children": "{{data.verdict[0].entities.entity_versions[0].data.persona_label}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "props": {
                      "as": "div",
                      "children": "{{data.verdict[0].entities.entity_versions[0].data.summary}}"
                    }
                  },
                  {
                    "type": "Text",
                    "props": {
                      "as": "div",
                      "weight": "medium",
                      "className": "rounded-md border border-amber-300 bg-amber-100/60 p-3",
                      "children": "Recommendation: {{data.verdict[0].entities.entity_versions[0].data.recommendation}}"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
